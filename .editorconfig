root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120
# @Composable functions are PascalCase by Compose convention; exempt them from
# the camelCase function-naming rule (mirrors the detekt config).
ktlint_function_naming_ignore_when_annotated_with = Composable
