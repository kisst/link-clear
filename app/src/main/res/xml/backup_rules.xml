<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android-12 (fullBackupContent) rules. Mirrors data_extraction_rules.xml:
  an ALLOWLIST, not a denylist. Auto Backup carries nothing unless explicitly
  included here, so the settings DataStore (which may hold a resolver API key in
  custom_resolver_url) and any future data cannot leak by default. There is
  currently nothing worth backing up, so the allowlist is intentionally empty.
-->
<full-backup-content>
    <exclude domain="root" path="." />
</full-backup-content>
