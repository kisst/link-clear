<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. Backup stays enabled for the app, but the
  settings DataStore is excluded from both cloud backup and device-to-device
  transfer: its custom_resolver_url field may hold a user's resolver API key,
  which should not leave the device. Everything else is eligible for backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="file"
            path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="file"
            path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
